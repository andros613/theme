---
interface Props {
  src: string;
  alt: string;
  title?: string;
  subtitle?: string;
  objectPosition?: string;
}
const { src, alt, title, subtitle, objectPosition = 'center 15%' } = Astro.props;
---

<div class="hero" id="hero" role="button" tabindex="0" aria-label="View full image">
  <img src={src} alt={alt} class="hero-img" style={`object-position: ${objectPosition}`} />
  {(title || subtitle) && (
    <div class="hero-overlay">
      {title    && <h1 class="hero-title">{title}</h1>}
      {subtitle && <p class="hero-subtitle">{subtitle}</p>}
    </div>
  )}
</div>

<div class="lightbox" id="lightbox" aria-modal="true" role="dialog" aria-label="Full image view" hidden>
  <img src={src} alt={alt} class="lightbox-img" />
  <button class="lightbox-close" aria-label="Close">✕</button>
</div>

<style>
  /* ── Hero banner ── */
  .hero {
    position: relative;
    /* break out of main's padding so the image is edge-to-edge within the container */
    margin-top: -2rem;
    margin-left: -1.5rem;
    margin-right: -1.5rem;
    width: calc(100% + 3rem);
    height: 300px;
    overflow: hidden;
    cursor: zoom-in;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 30, 70, 0.10) 0%,
      rgba(10, 30, 70, 0.55) 65%,
      rgba(10, 30, 70, 0.82) 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem 1.75rem;
  }
  .hero-title {
    font-size: 2rem;
    font-weight: 700;
    color: #fff;
    text-shadow: 0 1px 6px rgba(0,0,0,0.5);
    line-height: 1.15;
  }
  .hero-subtitle {
    color: rgba(255,255,255,0.82);
    font-size: 0.95rem;
    margin-top: 0.3rem;
    text-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }

  @media (max-width: 600px) {
    .hero       { height: 220px; }
    .hero-title { font-size: 1.5rem; }
    .hero-subtitle { font-size: 0.85rem; }
  }

  /* ── Lightbox ── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
    animation: lb-in 0.18s ease;
  }
  @keyframes lb-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .lightbox-img {
    max-width: 95vw;
    max-height: 92vh;
    object-fit: contain;
    border-radius: var(--radius);
    box-shadow: 0 8px 48px rgba(0,0,0,0.6);
    pointer-events: none;
  }
  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.25);
    color: #fff;
    font-size: 1.1rem;
    line-height: 1;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .lightbox-close:hover { background: rgba(255,255,255,0.25); }
</style>

<script>
  const hero     = document.getElementById('hero')!;
  const lightbox = document.getElementById('lightbox')!;
  const lbClose  = lightbox.querySelector('.lightbox-close')!;

  function open()  { lightbox.hidden = false; document.body.style.overflow = 'hidden'; }
  function close() { lightbox.hidden = true;  document.body.style.overflow = ''; }

  hero.addEventListener('click', open);
  hero.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') open(); });
  lightbox.addEventListener('click', e => { if (e.target === lightbox) close(); });
  lbClose.addEventListener('click', close);
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && !lightbox.hidden) close(); });
</script>
